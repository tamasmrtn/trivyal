# ── Hub ───────────────────────────────────────────────────────────────────────

# Required: long random string used to sign tokens. Generate with:
#   openssl rand -hex 32
TRIVYAL_SECRET_KEY=change-me-to-a-long-random-string

# Admin password for the web UI login (default: admin)
TRIVYAL_ADMIN_PASSWORD=admin

# Directory where the hub stores its SQLite database (default: /app/data)
# TRIVYAL_DATA_DIR=/app/data

# Override the SQLite connection URL (optional — derived from DATA_DIR by default)
# TRIVYAL_DATABASE_URL=sqlite+aiosqlite:////app/data/trivyal.db


# ── Agent (used by docker-compose.hub.yml for the co-located agent) ───────────

# Registration token and hub public key — both generated in the Trivyal UI
# (Agents → Add Agent). Copy the values shown there.
AGENT_TOKEN=
AGENT_HUB_KEY=

# WebSocket URL of the hub (only needed if running the agent separately)
# TRIVYAL_HUB_URL=ws://localhost:8099

# Cron expression for scheduled scans (default: nightly at 02:00)
# TRIVYAL_SCAN_SCHEDULE=0 2 * * *

# Advanced agent tuning (defaults shown)
# TRIVYAL_HEARTBEAT_INTERVAL=30
# TRIVYAL_RECONNECT_DELAY=10
